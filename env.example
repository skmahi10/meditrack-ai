# ===========================================
# MediTrack AI — Environment Variables
# ===========================================
# Copy this file as .env.local and fill in your actual values
# NEVER commit .env.local to GitHub
# ===========================================

# Firebase Configuration (Both Mahi and Faizan need these)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=meditrack-ai.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=meditrack-ai
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=meditrack-ai.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Gemini API (Backend only — Mahi)
GEMINI_API_KEY=your_gemini_api_key

# Google Maps API (Frontend — Faizan)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key
